{
  "manifest_version": 3,
  "name": "소싱 파이프라인 — 1688 클리퍼",
  "version": "1.0.0",
  "description": "1688.com 상품 이미지에 호버해서 소싱 후보를 DB에 바로 저장합니다.",

  "host_permissions": [
    "*://*.1688.com/*",
    "https://*.supabase.co/*"
  ],

  "content_scripts": [
    {
      "matches": ["*://*.1688.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ]
}
